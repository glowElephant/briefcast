# Briefcast 환경 설정

# 서버
HOST=0.0.0.0
PORT=8585

# Google Drive OAuth (credentials.json을 프로젝트 루트에 배치)
# Google Cloud Console > API > OAuth 2.0 클라이언트 ID에서 다운로드
GOOGLE_DRIVE_FOLDER_ID=

# 스케줄 (24시간 형식, 기본 06:00)
SCHEDULE_HOUR=6
SCHEDULE_MINUTE=0

# NotebookLM 오디오 설정
# 포맷: DEEP_DIVE | BRIEF | CRITIQUE | DEBATE
AUDIO_FORMAT=DEEP_DIVE
# 길이: SHORT | DEFAULT | LONG
AUDIO_LENGTH=DEFAULT

# 뉴스 수집 설정
MAX_ARTICLES_PER_TOPIC=10
ARTICLE_FETCH_DELAY=1.5
